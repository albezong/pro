<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Crea el perfil "SuperAdmin" con isSuperAdmin=true y lo asigna al usuario admin.
        isSuperAdmin=true da acceso total a todos los módulos sin necesitar
        registros en module_permission — es el bypass de BD para el usuario raíz.

        Si el perfil ya existe (re-run), el changeSet es ignorado porque tiene
        onFail="MARK_RAN" y la precondición lo protege.
    -->
    <changeSet id="20260427000001-superadmin-profile" author="sistema">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM profile WHERE name = 'SuperAdmin'
            </sqlCheck>
        </preConditions>

        <insert tableName="profile">
            <column name="id" valueSequenceNext="sequence_generator"/>
            <column name="name" value="SuperAdmin"/>
            <column name="description" value="Perfil con acceso total al sistema"/>
            <column name="active" valueBoolean="true"/>
            <column name="is_super_admin" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet id="20260427000001-assign-admin-to-superadmin" author="sistema">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM rel_profile__user ru
                JOIN profile p ON p.id = ru.profile_id
                JOIN jhi_user u ON u.id = ru.user_id
                WHERE p.name = 'SuperAdmin' AND u.login = 'admin'
            </sqlCheck>
        </preConditions>

        <sql>
            INSERT INTO rel_profile__user (profile_id, user_id)
            SELECT p.id, u.id
            FROM profile p, jhi_user u
            WHERE p.name = 'SuperAdmin'
              AND u.login = 'admin'
        </sql>
    </changeSet>

</databaseChangeLog>
